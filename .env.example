# ===== WhatsApp Cloud API (Meta) =====
# From Meta Business Suite -> WhatsApp -> API Setup
WHATSAPP_TOKEN=your_permanent_access_token_here
# Webhook verification - you make this up yourself, then enter the SAME value
# in Meta's webhook setup screen under "Verify Token"
WEBHOOK_VERIFY_TOKEN=choose_any_secret_string_here

# ===== Google Calendar API =====
# From Google Cloud Console -> APIs & Services -> Credentials
# This is a SERVICE ACCOUNT (not your personal Google login) - it gets
# its own email address like xxx@xxx.iam.gserviceaccount.com
# You then SHARE each salon's Google Calendar with that service account email
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json

# ===== Server =====
PORT=3000

# ===== Admin =====
# Simple password to protect the /admin route where you manage clients
ADMIN_SECRET=choose_another_secret_string
